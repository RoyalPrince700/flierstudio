PORT=8080
MONGODB_URI=mongodb://127.0.0.1:27017/flier-studio
JWT_SECRET=change-me-to-a-long-random-string

# Browser origin(s) allowed for CORS + credentialed cookies.
# Local:
CLIENT_URL=http://localhost:5173
# Production (canonical www). Comma-separate if apex also hits the app before redirects:
# CLIENT_URL=https://www.flierstudio.com
# CLIENT_URL=https://www.flierstudio.com,https://flierstudio.com

GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com
ADMIN_EMAIL=you@example.com
NODE_ENV=development
# Production: NODE_ENV=production (enables Secure + SameSite=None auth cookies)

# -----------------------------------------------------------------------------
# Mailtrap SMTP (welcome mail on first Google sign-in)
# Docs: https://docs.mailtrap.io
#
# Mode switch:
#   - Default: sandbox when NODE_ENV !== production, production sending otherwise
#   - Optional override: MAILTRAP_USE_SANDBOX=true|false
# -----------------------------------------------------------------------------

# Optional explicit override (true = Email Testing sandbox, false = live sending)
# MAILTRAP_USE_SANDBOX=true

# --- Sandbox SMTP (local + staging) ---
# Paste from: Mailtrap → Email Testing / Sandboxes → your inbox → Integration → SMTP
MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USERNAME=paste-sandbox-smtp-username
MAILTRAP_PASSWORD=paste-sandbox-smtp-password
MAILTRAP_FROM_EMAIL=hello@demomailtrap.com
MAILTRAP_FROM_NAME=Flier Studio

# --- Production SMTP (live sending) ---
# Paste from: Mailtrap → Sending Domains → your domain → Integration → SMTP
# Username is usually "api"; password is your sending API token.
MAILTRAP_PRODUCTION_HOST=live.smtp.mailtrap.io
MAILTRAP_PRODUCTION_PORT=587
MAILTRAP_PRODUCTION_USERNAME=api
MAILTRAP_PRODUCTION_PASSWORD=paste-production-sending-api-token
# Must be an address on a domain verified in Mailtrap Sending Domains
MAILTRAP_PRODUCTION_FROM_EMAIL=hello@your-verified-domain.com
MAILTRAP_PRODUCTION_FROM_NAME=Flier Studio
