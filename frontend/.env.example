# API base (no trailing slash). Frontend is the client — there is no CLIENT_URL here.
VITE_API_URL=http://localhost:8080
# Production example:
# VITE_API_URL=https://api.flierstudio.com

# Must match backend GOOGLE_CLIENT_ID (same Google Cloud OAuth Web client).
VITE_GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com

# Optional: only if you need absolute public links (canonical, shares). Not required for routing/auth.
# VITE_SITE_URL=https://www.flierstudio.com
